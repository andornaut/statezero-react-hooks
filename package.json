{
  "name": "statezero-react-hooks",
  "version": "0.1.0",
  "author": "andornaut",
  "description": "React hooks for Statezero",
  "keywords": [
    "functional",
    "immutable",
    "state",
    "react",
    "hooks"
  ],
  "license": "MIT",
  "main": "dist/statezero-react-hooks.js",
  "module": "dist/statezero-react-hooks.esm.js",
  "browser": "./dist/statezero-react-hooks.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/statezero-react-hooks.esm.js",
      "require": "./dist/statezero-react-hooks.js"
    },
    "./src": {
      "import": "./src/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/andornaut/statezero-react-hooks/issues"
  },
  "homepage": "https://github.com/andornaut/statezero-react-hooks#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/andornaut/statezero-react-hooks.git"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "statezero": ">=0.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@testing-library/react": "^16.3.2",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^12.0.0",
    "statezero": "^0.9.0"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:umd",
    "build:esm": "esbuild src/index.js --bundle --format=esm --packages=external --outfile=dist/statezero-react-hooks.esm.js",
    "build:production": "npm run build:esm -- --minify && npm run build:umd -- --minify",
    "build:umd": "esbuild src/index.js --bundle --format=iife --global-name=statezeroReactHooks --external:react --external:statezero --outfile=dist/statezero-react-hooks.js",
    "format": "prettier --write \"{src,test}/**/*.js\" \"*.{json,md}\"",
    "lint": "eslint --max-warnings 0 {src,test}/**/*.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run build:production",
    "size": "size-limit",
    "test": "jest",
    "test:watch": "jest --watch"
  }
}
